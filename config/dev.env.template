# =============================================================================
# AI Agent Skeleton — Development Environment Template
# Copy to .env and fill in your API keys
# =============================================================================

# LLM Provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# API Keys (set the one matching your LLM_PROVIDER)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Database (defaults match docker-compose.yml)
# DATABASE_URL=postgresql+asyncpg://appdev:appdev@localhost:5432/app

# Redis (defaults match docker-compose.yml)
# REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated origins; empty = localhost defaults)
# CORS_ALLOWED_ORIGINS=http://localhost:5173

# Rate limiting
# RATE_LIMIT_PER_MINUTE=30

# Compute timeout (seconds)
# COMPUTE_TIMEOUT_SEC=30

# Chat SLA target (seconds)
# CHAT_SLA_SEC=3.0

# LLM sampling (deterministic defaults)
# LLM_TEMPERATURE=0.0
# LLM_TOP_P=1.0
